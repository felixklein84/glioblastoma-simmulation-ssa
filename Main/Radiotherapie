using Random
using Plots
using Distributions

Random.seed!(1234)

struct ReactionStruct_Radio
    transitions::Vector{Int}
    reac_prob::Function
end

mutable struct SSA_Struct_Radio
    reactions::Vector{ReactionStruct_Radio}
    state::Vector{Int}
    t::Float64
    time_points::Vector{Float64}
    hit_counts::Vector{Vector{Int}}
    radiotherapy_time::Float64
    radiotherapy_done::Bool
end

function initialize_ssa(reactions, initial_state, radiotherapy_time)
    SSA_Struct_Radio(reactions, initial_state, 0.0, [0.0], [copy(initial_state)], radiotherapy_time, false)
end

function compute_total_prob(reactions, state)
    total_prob = 0.0
    for r in reactions
        total_prob += r.reac_prob(state)
    end
    return total_prob
end

function update_state!(ssa::SSA_Struct_Radio, reaction_index)
    ssa.state .+= ssa.reactions[reaction_index].transitions
    push!(ssa.hit_counts, copy(ssa.state))
end

function select_reaction(reactions, state, total_prob)
    r = rand() * total_prob
    cumulative_sum = 0.0
    for (i, reaction) in enumerate(reactions)
        cumulative_sum += reaction.reac_prob(state)
        if cumulative_sum > r
            return i
        end
    end
end

function run_ssa!(ssa::SSA_Struct_Radio, max_time)
    while ssa.t < max_time
        if !ssa.radiotherapy_done && ssa.t >= ssa.radiotherapy_time
            ssa.state[1] = round(Int, rt_dying_percentage[1] * ssa.state[1])  # Reduziere EP auf Radiotherapie Sterbewahrscheinlichkeit
            ssa.state[2] = round(Int, rt_dying_percentage[3] * ssa.state[2])
            ssa.state[3] = round(Int, rt_dying_percentage[3] * ssa.state[3])
            ssa.radiotherapy_done = true
        end

        total_prob = compute_total_prob(ssa.reactions, ssa.state)
        if total_prob == 0
            break
        end

        dt = rand(Exponential(1 / total_prob))
        ssa.t += dt
        push!(ssa.time_points, ssa.t)

        reaction_index = select_reaction(ssa.reactions, ssa.state, total_prob)
        update_state!(ssa, reaction_index)
    end
end

function create_reactions(rates)
    return [
        ReactionStruct_Radio([1, 0, 0], x -> rates[1] * x[1]),  # EP birth
        ReactionStruct_Radio([-1, 0, 0], x -> rates[2] * x[1]),  # EP death
        ReactionStruct_Radio([-1, 1, 0], x -> rates[3] * x[1]),  # EP to MP
        ReactionStruct_Radio([-1, 0, 1], x -> rates[4] * x[1]),  # EP to Diff

        ReactionStruct_Radio([0, 1, 0], x -> rates[5] * x[2]),  # MP birth
        ReactionStruct_Radio([0, -1, 0], x -> rates[6] * x[2]),  # MP death
        ReactionStruct_Radio([1, -1, 0], x -> rates[7] * x[2]),  # MP to EP
        ReactionStruct_Radio([0, -1, 1], x -> rates[8] * x[2]),  # MP to Diff

        ReactionStruct_Radio([0, 0, 1], x -> rates[9] * x[3]),  # Diff birth
        ReactionStruct_Radio([0, 0, -1], x -> rates[10] * x[3]),  # Diff death
        ReactionStruct_Radio([1, 0, -1], x -> rates[11] * x[3]),  # Diff to EP
        ReactionStruct_Radio([0, 1, -1], x -> rates[12] * x[3])   # Diff to MP
    ]
end

function run_simulation(initial_state, rates, max_time, radiotherapy_time)
    reactions = create_reactions(rates)
    ssa = initialize_ssa(reactions, initial_state, radiotherapy_time)
    run_ssa!(ssa, max_time)
    return ssa
end

# Beispiel: 
initial_state = [10, 10, 10] # EP, MP, Diff
rates = [
    0.01, 0, 0.0265, 0.0008,
    0, 0, 0.0175, 0.0121,
    0, 0, 0.0018, 0.0201
    ]
rt_dying_percentage = [0.0952380952380952, 0.13953488372093, 0.333333333333333]
radiotherapy_time = 100.0
run_time = 300.0

# Simulation ausführen
ssa = run_simulation(initial_state, rates, run_time, radiotherapy_time)

time_points = ssa.time_points
hit_counts = ssa.hit_counts

# Anzahl der Zustände trennen
state1_hits = [count[1] for count in hit_counts]
state2_hits = [count[2] for count in hit_counts]
state3_hits = [count[3] for count in hit_counts]

# Plot für Anzahl der Zustände
plot1 =plot(time_points, state1_hits, label="EP", xlabel="Time", ylabel="# of tumor cells", title="# of tumor cells vs Time", color = "green")
plot!(time_points, state2_hits, label="MP", color = "red")
plot!(time_points, state3_hits, label="Diff", color = "blue")

# Plot für Anteil der Zustände
total_cells = [sum(count) for count in hit_counts]
norm_state1_hits = state1_hits ./ total_cells
norm_state2_hits = state2_hits ./ total_cells
norm_state3_hits = state3_hits ./ total_cells

cumulative_norm_state2_hits = norm_state1_hits + norm_state2_hits
cumulative_norm_state3_hits = cumulative_norm_state2_hits + norm_state3_hits

plot2 = plot(time_points, norm_state1_hits, fillrange=0, fillalpha=0.3, label="EP", xlabel="Time", ylabel="Proportion", title="Proportion of tumor cells vs Time", color="green")
plot!(time_points, cumulative_norm_state2_hits, fillrange=norm_state1_hits, fillalpha=0.3, label="MP", color="red")
plot!(time_points, cumulative_norm_state3_hits, fillrange=cumulative_norm_state2_hits, fillalpha=0.3, label="Diff", color="blue")

# Plot Tumorgröße vs Zeit
plot3 = plot(time_points, total_cells, label="Radiotherapy", xlabel="Time", ylabel="Tumorsize", title="Tumorsize vs Time", color = "pink")

# Plot ausgeben
display(plot1)
display(plot2)
display(plot(plot1, plot2, layout=(1, 2)))
display(plot3)